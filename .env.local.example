# Sanity — fill these in after creating a project at https://sanity.io/manage
# (or run `npx sanity init` inside the ./studio folder).

# Website (Next.js)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Server-only Viewer token (create at sanity.io/manage → API → Tokens)
# Required if anonymous dataset reads are blocked. Never use NEXT_PUBLIC_ for this.
SANITY_API_READ_TOKEN=

# Studio / CLI
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production
